# Version control
.git
.gitignore

# Node/Bun — each stage runs its own bun install
**/node_modules
**/dist
**/.turbo

# Test files — not needed in production images
**/*.test.ts
**/*.integration.test.ts
**/vitest.config.ts
**/vitest.integration.config.ts
**/__tests__

# IDE and OS
.vscode
.idea
.DS_Store
*.swp
**/.claude

# Docs and site — not needed at runtime
docs/
apps/site/
*.md
!**/package.json

# Infra / scripts — not needed in app images
infra/
scripts/
.github/
.gstack/

# Docker files themselves
Dockerfile*
docker-compose*.yml
.dockerignore

# Misc
.env*
*.log
coverage/
.oxlintrc.json
