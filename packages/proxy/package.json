{
  "name": "@paws/proxy",
  "version": "0.1.0",
  "private": true,
  "description": "TLS MITM credential injection proxy — zero secrets in the sandbox",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
