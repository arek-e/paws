{
  "name": "@paws/snapshot-store",
  "version": "0.1.0",
  "private": true,
  "description": "S3-compatible storage client for Firecracker VM snapshot CRUD — targets Cloudflare R2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/lib-storage": "^3.800.0",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "vitest": "^4.1.2"
  }
}
