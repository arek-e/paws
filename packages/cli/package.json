{
  "name": "@paws/cli",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tool for the paws Gateway API",
  "bin": {
    "paws": "./src/index.ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build --compile --outfile dist/paws src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@paws/domain-fleet": "workspace:*",
    "@paws/domain-session": "workspace:*",
    "@paws/sdk": "workspace:*",
    "ink": "^6.0.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "neverthrow": "^8.2.0",
    "vitest": "^4.1.2"
  }
}
