{
  "name": "@paws/runtime-firecracker",
  "version": "0.1.0",
  "private": true,
  "description": "Firecracker runtime adapter — KVM-isolated VM execution with TLS MITM credential injection",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paws/firecracker": "workspace:*",
    "@paws/logger": "workspace:*",
    "@paws/proxy": "workspace:*",
    "@paws/runtime": "workspace:*",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "vitest": "^4.1.2"
  }
}
