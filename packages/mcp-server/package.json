{
  "name": "@paws/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for paws — lets AI agents manage servers, sessions, and daemons",
  "bin": {
    "paws-mcp": "./src/index.ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@paws/sdk": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
