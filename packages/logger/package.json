{
  "name": "@paws/logger",
  "version": "0.1.0",
  "private": true,
  "description": "Structured JSON logger for paws services",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
