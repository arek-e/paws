{
  "name": "@paws/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript client for the paws Gateway API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paws/types": "workspace:*",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "vitest": "^4.1.2"
  }
}
