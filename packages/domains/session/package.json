{
  "name": "@paws/domain-session",
  "version": "0.1.0",
  "private": true,
  "description": "Session domain — Session, SessionStore, events, routes, WebSocket messages",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@paws/domain-browser": "workspace:*",
    "@paws/domain-common": "workspace:*",
    "@paws/domain-network": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
