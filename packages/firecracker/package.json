{
  "name": "@paws/firecracker",
  "version": "0.1.0",
  "private": true,
  "description": "Firecracker VM lifecycle — client, networking, snapshot restore",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@paws/domain-network": "workspace:*",
    "neverthrow": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
