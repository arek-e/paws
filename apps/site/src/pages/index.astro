---
const title = 'paws — Protected Agent Workflow System';
const description = 'Zero-trust credential injection for AI agents. Secrets never enter the sandbox — they are injected at the network layer by a per-VM TLS MITM proxy.';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://getpaws.dev" />
    <meta property="og:image" content="https://getpaws.dev/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://getpaws.dev/og.png" />
    <style>
      /* Reset */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --emerald-400: #34d399;
        --emerald-500: #10b981;
        --emerald-600: #059669;
        --emerald-900: #064e3b;
        --zinc-50: #fafafa;
        --zinc-100: #f4f4f5;
        --zinc-200: #e4e4e7;
        --zinc-300: #d4d4d8;
        --zinc-400: #a1a1aa;
        --zinc-500: #71717a;
        --zinc-600: #52525b;
        --zinc-700: #3f3f46;
        --zinc-800: #27272a;
        --zinc-900: #18181b;
        --zinc-950: #09090b;
      }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: var(--zinc-950);
        color: var(--zinc-300);
        line-height: 1.6;
        overflow-x: hidden;
      }

      a { color: var(--emerald-400); text-decoration: none; }
      a:hover { color: var(--emerald-500); }

      /* Utilities */
      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .mono {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
      }

      /* Nav */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(9, 9, 11, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--zinc-800);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--zinc-50);
        font-size: 1.125rem;
      }

      .nav-logo img { width: 28px; height: 28px; }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 2rem;
        list-style: none;
      }

      .nav-links a {
        color: var(--zinc-400);
        font-size: 0.875rem;
        transition: color 0.15s;
      }

      .nav-links a:hover { color: var(--zinc-50); }

      .nav-links .gh-link {
        display: flex;
        align-items: center;
        gap: 0.375rem;
      }

      .nav-links .gh-link svg { width: 18px; height: 18px; }

      /* Hero */
      .hero {
        padding: 10rem 0 6rem;
        text-align: center;
        position: relative;
      }

      .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 600px;
        background: radial-gradient(ellipse, rgba(52, 211, 153, 0.06) 0%, transparent 70%);
        pointer-events: none;
      }

      .hero-cat-scene {
        position: relative;
        display: inline-block;
      }

      .hero-cat {
        color: var(--emerald-400);
        font-size: 1rem;
        line-height: 1.4;
        animation: cat-float 3s ease-in-out infinite;
        margin-bottom: 2rem;
        opacity: 0.7;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        color: var(--zinc-50);
        letter-spacing: -0.03em;
        line-height: 1.15;
        max-width: 720px;
        margin: 0 auto 1.5rem;
      }

      .hero h1 .accent { color: var(--emerald-400); }

      .hero-sub {
        font-size: 1.125rem;
        color: var(--zinc-400);
        max-width: 560px;
        margin: 0 auto 3rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      /* Waitlist form */
      .waitlist-form {
        display: flex;
        gap: 0.5rem;
        width: 100%;
        max-width: 440px;
      }

      .waitlist-form input {
        flex: 1;
        padding: 0.75rem 1rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-700);
        border-radius: 8px;
        color: var(--zinc-100);
        font-size: 0.9375rem;
        outline: none;
        transition: border-color 0.15s;
        font-family: inherit;
      }

      .waitlist-form input::placeholder { color: var(--zinc-600); }
      .waitlist-form input:focus { border-color: var(--emerald-400); }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: var(--emerald-600);
        color: white;
        font-weight: 600;
        font-size: 0.9375rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s;
        white-space: nowrap;
        font-family: inherit;
      }

      .btn-primary:hover { background: var(--emerald-500); }

      .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .waitlist-success {
        color: var(--emerald-400);
        font-size: 0.875rem;
        display: none;
      }

      .waitlist-error {
        color: #ef4444;
        font-size: 0.875rem;
        display: none;
      }

      /* Install command */
      .install-cmd {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 8px;
        padding: 0.625rem 0.75rem 0.625rem 1rem;
        max-width: 520px;
        width: 100%;
      }

      .install-cmd code {
        flex: 1;
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        color: var(--zinc-300);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .install-cmd .prefix { color: var(--emerald-400); }

      .copy-btn {
        background: none;
        border: 1px solid var(--zinc-700);
        border-radius: 6px;
        padding: 0.375rem 0.625rem;
        color: var(--zinc-400);
        cursor: pointer;
        font-size: 0.75rem;
        font-family: inherit;
        transition: all 0.15s;
        white-space: nowrap;
      }

      .copy-btn:hover {
        border-color: var(--zinc-500);
        color: var(--zinc-200);
      }

      /* Section shared */
      section {
        padding: 6rem 0;
      }

      .section-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--emerald-400);
        margin-bottom: 1rem;
      }

      .section-title {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 700;
        color: var(--zinc-50);
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }

      .section-desc {
        color: var(--zinc-400);
        font-size: 1.0625rem;
        max-width: 560px;
        margin-bottom: 3rem;
      }

      /* How it works */
      .how-it-works {
        border-top: 1px solid var(--zinc-800);
      }

      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
      }

      .step {
        position: relative;
        padding: 1.5rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        transition: border-color 0.2s;
      }

      .step:hover { border-color: var(--zinc-700); }

      .step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--emerald-900);
        color: var(--emerald-400);
        font-size: 0.8125rem;
        font-weight: 700;
        margin-bottom: 1rem;
      }

      .step h3 {
        color: var(--zinc-50);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }

      .step p {
        font-size: 0.875rem;
        color: var(--zinc-400);
        line-height: 1.6;
      }

      /* Request flow diagram */
      .flow-diagram {
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        padding: 2rem;
        overflow-x: auto;
      }

      .flow-diagram pre {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        line-height: 1.7;
        color: var(--zinc-300);
        margin: 0;
      }

      .flow-diagram .hl { color: var(--emerald-400); }
      .flow-diagram .dim { color: var(--zinc-600); }
      .flow-diagram .warn { color: #fbbf24; }

      /* Features */
      .features {
        border-top: 1px solid var(--zinc-800);
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }

      .feature-card {
        padding: 1.5rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        transition: border-color 0.2s;
      }

      .feature-card:hover { border-color: var(--zinc-700); }

      .feature-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--emerald-900);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        color: var(--emerald-400);
      }

      .feature-icon svg { width: 20px; height: 20px; }

      .feature-card h3 {
        color: var(--zinc-50);
        font-size: 0.9375rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }

      .feature-card p {
        font-size: 0.8125rem;
        color: var(--zinc-500);
        line-height: 1.6;
      }

      /* Architecture */
      .architecture {
        border-top: 1px solid var(--zinc-800);
      }

      .arch-diagram {
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        padding: 2.5rem;
        overflow-x: auto;
      }

      .arch-diagram pre {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        line-height: 1.6;
        color: var(--zinc-300);
        margin: 0;
      }

      .arch-diagram .hl { color: var(--emerald-400); }
      .arch-diagram .dim { color: var(--zinc-600); }

      /* CTA */
      .cta {
        border-top: 1px solid var(--zinc-800);
        text-align: center;
      }

      .cta-inner {
        max-width: 560px;
        margin: 0 auto;
      }

      .cta-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: transparent;
        color: var(--zinc-300);
        font-weight: 500;
        font-size: 0.9375rem;
        border: 1px solid var(--zinc-700);
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
        font-family: inherit;
      }

      .btn-secondary:hover {
        border-color: var(--zinc-500);
        color: var(--zinc-50);
      }

      .btn-secondary svg { width: 18px; height: 18px; }

      /* Footer */
      footer {
        border-top: 1px solid var(--zinc-800);
        padding: 2rem 0;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.8125rem;
        color: var(--zinc-600);
      }

      .footer-links {
        display: flex;
        gap: 1.5rem;
        list-style: none;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-weight: 500;
      }

      .footer-links a { color: var(--zinc-500); }
      .footer-links a:hover { color: var(--zinc-300); }

      /* Code Examples (tabs) */
      .code-examples {
        border-top: 1px solid var(--zinc-800);
      }

      .tab-switcher {
        display: flex;
        gap: 0;
        border-bottom: 2px solid var(--zinc-800);
        margin-bottom: 1.5rem;
      }

      .tab-btn {
        padding: 0.75rem 1.5rem;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        color: var(--zinc-500);
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        font-family: inherit;
        transition: color 0.15s, border-color 0.15s;
      }

      .tab-btn:hover { color: var(--zinc-300); }

      .tab-btn.active {
        color: var(--emerald-400);
        border-bottom-color: var(--emerald-400);
      }

      .tab-panel {
        display: none;
      }

      .tab-panel.active {
        display: block;
      }

      .code-block {
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        padding: 1.5rem;
        overflow-x: auto;
      }

      .code-block pre {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        line-height: 1.7;
        color: var(--zinc-300);
        margin: 0;
      }

      .code-block .kw { color: #60a5fa; }
      .code-block .str { color: var(--emerald-400); }
      .code-block .cm { color: var(--zinc-600); }
      .code-block .fn { color: #c084fc; }
      .code-block .pr { color: #fbbf24; }
      .code-block .op { color: var(--zinc-500); }

      /* Performance Metrics */
      .metrics-banner {
        border-top: 1px solid var(--zinc-800);
        padding: 4rem 0;
      }

      .metrics-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        text-align: center;
      }

      .metric-item {
        padding: 1.5rem 1rem;
      }

      .metric-value {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 700;
        color: var(--emerald-400);
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-bottom: 0.5rem;
      }

      .metric-label {
        font-size: 0.8125rem;
        color: var(--zinc-500);
        line-height: 1.4;
      }

      /* Use Cases */
      .use-cases {
        border-top: 1px solid var(--zinc-800);
      }

      .use-case-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .use-case-card {
        padding: 1.5rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        transition: border-color 0.2s;
      }

      .use-case-card:hover { border-color: var(--zinc-700); }

      .use-case-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }

      .use-case-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--emerald-900);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--emerald-400);
        flex-shrink: 0;
      }

      .use-case-icon svg { width: 20px; height: 20px; }

      .use-case-card h3 {
        color: var(--zinc-50);
        font-size: 0.9375rem;
        font-weight: 600;
      }

      .trigger-badge {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        background: rgba(52, 211, 153, 0.1);
        border: 1px solid rgba(52, 211, 153, 0.2);
        border-radius: 9999px;
        font-size: 0.6875rem;
        font-weight: 500;
        color: var(--emerald-400);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.75rem;
      }

      .use-case-card p {
        font-size: 0.8125rem;
        color: var(--zinc-500);
        line-height: 1.6;
      }

      /* Security Deep-Dive */
      .security-deep-dive {
        border-top: 1px solid var(--zinc-800);
      }

      .security-flow {
        display: flex;
        align-items: stretch;
        gap: 0;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 2rem;
      }

      .sec-box {
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--zinc-800);
        background: var(--zinc-900);
        min-width: 200px;
        flex: 1;
        max-width: 280px;
      }

      .sec-box h4 {
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
      }

      .sec-box ul {
        list-style: none;
        padding: 0;
      }

      .sec-box ul li {
        font-size: 0.8125rem;
        color: var(--zinc-400);
        padding: 0.25rem 0;
        padding-left: 1.25rem;
        position: relative;
      }

      .sec-box ul li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.625rem;
        width: 6px;
        height: 6px;
        border-radius: 50%;
      }

      .sec-box-vm { border-color: var(--emerald-400); }
      .sec-box-vm h4 { color: var(--emerald-400); }
      .sec-box-vm ul li::before { background: var(--emerald-400); }

      .sec-box-proxy { border-color: #60a5fa; }
      .sec-box-proxy h4 { color: #60a5fa; }
      .sec-box-proxy ul li::before { background: #60a5fa; }

      .sec-box-api { border-color: #c084fc; }
      .sec-box-api h4 { color: #c084fc; }
      .sec-box-api ul li::before { background: #c084fc; }

      .sec-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 0.75rem;
        color: var(--zinc-600);
        font-size: 1.5rem;
        flex-shrink: 0;
      }

      .sec-blocked {
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .sec-blocked-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: rgba(239, 68, 68, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ef4444;
        flex-shrink: 0;
      }

      .sec-blocked-icon svg { width: 20px; height: 20px; }

      .sec-blocked-text h4 {
        color: #ef4444;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
      }

      .sec-blocked-text p {
        font-size: 0.8125rem;
        color: var(--zinc-500);
      }

      /* Responsive */
      /* Cat animations */
      @keyframes cat-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-6px); }
      }

      @keyframes cat-blink {
        0%, 90%, 100% { opacity: 1; }
        95% { opacity: 0; }
      }

      @keyframes cat-tail {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(8deg); }
        75% { transform: rotate(-8deg); }
      }

      .cat-blink {
        position: absolute;
        top: 1.4em;
        left: 2.6em;
        width: 0.6em;
        height: 0.2em;
        animation: cat-blink 4s ease-in-out infinite;
      }

      /* Section cat decorations */
      .section-cat-inline {
        color: var(--zinc-600);
        font-size: 0.75rem;
        line-height: 1.3;
        text-align: center;
        margin: 0.5rem auto 1.5rem;
        animation: cat-float 4s ease-in-out infinite;
        animation-delay: 1s;
      }

      @media (max-width: 768px) {
        .hero { padding: 7rem 0 4rem; }

        .steps { grid-template-columns: 1fr; }

        .feature-grid { grid-template-columns: 1fr; }

        .metrics-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }

        .use-case-grid { grid-template-columns: 1fr; }

        .security-flow { flex-direction: column; align-items: center; }
        .sec-arrow { transform: rotate(90deg); padding: 0.5rem 0; }

        .nav-links { gap: 1rem; }

        .waitlist-form { flex-direction: column; }

        .footer-inner {
          flex-direction: column;
          gap: 1rem;
          text-align: center;
        }
      }

      @media (max-width: 480px) {
        .nav-links .hide-mobile { display: none; }
      }
    </style>
  </head>

  <body>
    <!-- Nav -->
    <nav>
      <div class="container nav-inner">
        <a href="/" class="nav-logo">
          <img src="/favicon.svg" alt="" width="28" height="28" />
          paws
        </a>
        <ul class="nav-links">
          <li><a href="#how-it-works" class="hide-mobile">How it works</a></li>
          <li><a href="#features" class="hide-mobile">Features</a></li>
