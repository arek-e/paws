---
const title = 'paws — Protected Agent Workspace Sandboxes';
const description = 'Zero-trust credential injection for AI agents. Secrets never enter the sandbox — they are injected at the network layer by a per-VM TLS MITM proxy.';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://getpaws.dev" />
    <meta name="twitter:card" content="summary_large_image" />
    <style>
      /* Reset */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --emerald-400: #34d399;
        --emerald-500: #10b981;
        --emerald-600: #059669;
        --emerald-900: #064e3b;
        --zinc-50: #fafafa;
        --zinc-100: #f4f4f5;
        --zinc-200: #e4e4e7;
        --zinc-300: #d4d4d8;
        --zinc-400: #a1a1aa;
        --zinc-500: #71717a;
        --zinc-600: #52525b;
        --zinc-700: #3f3f46;
        --zinc-800: #27272a;
        --zinc-900: #18181b;
        --zinc-950: #09090b;
      }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: var(--zinc-950);
        color: var(--zinc-300);
        line-height: 1.6;
        overflow-x: hidden;
      }

      a { color: var(--emerald-400); text-decoration: none; }
      a:hover { color: var(--emerald-500); }

      /* Utilities */
      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .mono {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
      }

      /* Nav */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(9, 9, 11, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--zinc-800);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--zinc-50);
        font-size: 1.125rem;
      }

      .nav-logo svg { width: 28px; height: 28px; }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 2rem;
        list-style: none;
      }

      .nav-links a {
        color: var(--zinc-400);
        font-size: 0.875rem;
        transition: color 0.15s;
      }

      .nav-links a:hover { color: var(--zinc-50); }

      .nav-links .gh-link {
        display: flex;
        align-items: center;
        gap: 0.375rem;
      }

      .nav-links .gh-link svg { width: 18px; height: 18px; }

      /* Hero */
      .hero {
        padding: 10rem 0 6rem;
        text-align: center;
        position: relative;
      }

      .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 600px;
        background: radial-gradient(ellipse, rgba(52, 211, 153, 0.06) 0%, transparent 70%);
        pointer-events: none;
      }

      .hero-cat {
        color: var(--emerald-400);
        font-size: 1rem;
        line-height: 1.4;
        margin-bottom: 2rem;
        opacity: 0.7;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        color: var(--zinc-50);
        letter-spacing: -0.03em;
        line-height: 1.15;
        max-width: 720px;
        margin: 0 auto 1.5rem;
      }

      .hero h1 .accent { color: var(--emerald-400); }

      .hero-sub {
        font-size: 1.125rem;
        color: var(--zinc-400);
        max-width: 560px;
        margin: 0 auto 3rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      /* Waitlist form */
      .waitlist-form {
        display: flex;
        gap: 0.5rem;
        width: 100%;
        max-width: 440px;
      }

      .waitlist-form input {
        flex: 1;
        padding: 0.75rem 1rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-700);
        border-radius: 8px;
        color: var(--zinc-100);
        font-size: 0.9375rem;
        outline: none;
        transition: border-color 0.15s;
        font-family: inherit;
      }

      .waitlist-form input::placeholder { color: var(--zinc-600); }
      .waitlist-form input:focus { border-color: var(--emerald-400); }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: var(--emerald-600);
        color: white;
        font-weight: 600;
        font-size: 0.9375rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s;
        white-space: nowrap;
        font-family: inherit;
      }

      .btn-primary:hover { background: var(--emerald-500); }

      .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .waitlist-success {
        color: var(--emerald-400);
        font-size: 0.875rem;
        display: none;
      }

      .waitlist-error {
        color: #ef4444;
        font-size: 0.875rem;
        display: none;
      }

      /* Install command */
      .install-cmd {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 8px;
        padding: 0.625rem 0.75rem 0.625rem 1rem;
        max-width: 520px;
        width: 100%;
      }

      .install-cmd code {
        flex: 1;
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        color: var(--zinc-300);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .install-cmd .prefix { color: var(--emerald-400); }

      .copy-btn {
        background: none;
        border: 1px solid var(--zinc-700);
        border-radius: 6px;
        padding: 0.375rem 0.625rem;
        color: var(--zinc-400);
        cursor: pointer;
        font-size: 0.75rem;
        font-family: inherit;
        transition: all 0.15s;
        white-space: nowrap;
      }

      .copy-btn:hover {
        border-color: var(--zinc-500);
        color: var(--zinc-200);
      }

      /* Section shared */
      section {
        padding: 6rem 0;
      }

      .section-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--emerald-400);
        margin-bottom: 1rem;
      }

      .section-title {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 700;
        color: var(--zinc-50);
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }

      .section-desc {
        color: var(--zinc-400);
        font-size: 1.0625rem;
        max-width: 560px;
        margin-bottom: 3rem;
      }

      /* How it works */
      .how-it-works {
        border-top: 1px solid var(--zinc-800);
      }

      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 3rem;
      }

      .step {
        position: relative;
        padding: 1.5rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        transition: border-color 0.2s;
      }

      .step:hover { border-color: var(--zinc-700); }

      .step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--emerald-900);
        color: var(--emerald-400);
        font-size: 0.8125rem;
        font-weight: 700;
        margin-bottom: 1rem;
      }

      .step h3 {
        color: var(--zinc-50);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }

      .step p {
        font-size: 0.875rem;
        color: var(--zinc-400);
        line-height: 1.6;
      }

      /* Request flow diagram */
      .flow-diagram {
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        padding: 2rem;
        overflow-x: auto;
      }

      .flow-diagram pre {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        line-height: 1.7;
        color: var(--zinc-300);
        margin: 0;
      }

      .flow-diagram .hl { color: var(--emerald-400); }
      .flow-diagram .dim { color: var(--zinc-600); }
      .flow-diagram .warn { color: #fbbf24; }

      /* Features */
      .features {
        border-top: 1px solid var(--zinc-800);
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }

      .feature-card {
        padding: 1.5rem;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        transition: border-color 0.2s;
      }

      .feature-card:hover { border-color: var(--zinc-700); }

      .feature-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--emerald-900);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        color: var(--emerald-400);
      }

      .feature-icon svg { width: 20px; height: 20px; }

      .feature-card h3 {
        color: var(--zinc-50);
        font-size: 0.9375rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }

      .feature-card p {
        font-size: 0.8125rem;
        color: var(--zinc-500);
        line-height: 1.6;
      }

      /* Architecture */
      .architecture {
        border-top: 1px solid var(--zinc-800);
      }

      .arch-diagram {
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        padding: 2.5rem;
        overflow-x: auto;
      }

      .arch-diagram pre {
        font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.8125rem;
        line-height: 1.6;
        color: var(--zinc-300);
        margin: 0;
      }

      .arch-diagram .hl { color: var(--emerald-400); }
      .arch-diagram .dim { color: var(--zinc-600); }

      /* CTA */
      .cta {
        border-top: 1px solid var(--zinc-800);
        text-align: center;
      }

      .cta-inner {
        max-width: 560px;
        margin: 0 auto;
      }

      .cta-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: transparent;
        color: var(--zinc-300);
        font-weight: 500;
        font-size: 0.9375rem;
        border: 1px solid var(--zinc-700);
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
        font-family: inherit;
      }

      .btn-secondary:hover {
        border-color: var(--zinc-500);
        color: var(--zinc-50);
      }

      .btn-secondary svg { width: 18px; height: 18px; }

      /* Footer */
      footer {
        border-top: 1px solid var(--zinc-800);
        padding: 2rem 0;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.8125rem;
        color: var(--zinc-600);
      }

      .footer-links {
        display: flex;
        gap: 1.5rem;
        list-style: none;
      }

      .footer-links a { color: var(--zinc-500); }
      .footer-links a:hover { color: var(--zinc-300); }

      /* Responsive */
      @media (max-width: 768px) {
        .hero { padding: 7rem 0 4rem; }

        .steps { grid-template-columns: 1fr; }

        .feature-grid { grid-template-columns: 1fr; }

        .nav-links { gap: 1rem; }

        .waitlist-form { flex-direction: column; }

        .footer-inner {
          flex-direction: column;
          gap: 1rem;
          text-align: center;
        }
      }

      @media (max-width: 480px) {
        .nav-links .hide-mobile { display: none; }
      }
    </style>
  </head>

  <body>
    <!-- Nav -->
    <nav>
      <div class="container nav-inner">
        <a href="/" class="nav-logo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
          </svg>
          paws
        </a>
        <ul class="nav-links">
          <li><a href="#how-it-works" class="hide-mobile">How it works</a></li>
          <li><a href="#features" class="hide-mobile">Features</a></li>
          <li><a href="/getting-started/install/">Docs</a></li>
          <li>
            <a href="https://github.com/arek-e/paws" class="gh-link" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              <span>GitHub</span>
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <pre class="hero-cat mono">{`  /\\_/\\
 ( o.o )
  > ^ <`}</pre>
        <h1>Your agent should have <span class="accent">nothing worth stealing</span></h1>
        <p class="hero-sub">
          Zero-trust credential injection for AI agents. Secrets never enter the sandbox —
          they're injected at the network layer by a per-VM TLS proxy.
        </p>
        <div class="hero-actions">
          <form class="waitlist-form" id="waitlist-form">
            <input type="email" name="email" placeholder="you@company.com" required autocomplete="email" />
            <button type="submit" class="btn-primary">Join waitlist</button>
          </form>
          <p class="waitlist-success" id="waitlist-success">You're on the list. We'll be in touch.</p>
          <p class="waitlist-error" id="waitlist-error"></p>
          <div class="install-cmd">
            <code><span class="prefix">$</span> curl -fsSL https://getpaws.dev/install.sh | bash</code>
            <button class="copy-btn" id="copy-btn" type="button">Copy</button>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how-it-works" id="how-it-works">
      <div class="container">
        <p class="section-label">How it works</p>
        <h2 class="section-title">Credentials injected, never exposed</h2>
        <p class="section-desc">
          Agents run in ephemeral Firecracker microVMs with zero secrets on disk, in env, or in memory.
          A per-VM TLS proxy intercepts outbound HTTPS and injects credentials on-the-fly.
        </p>

        <div class="steps">
          <div class="step">
            <div class="step-number">1</div>
            <h3>Agent runs in VM</h3>
            <p>Each session gets a fresh Firecracker microVM restored from a memory snapshot in under a second. No API keys, no tokens, no secrets inside.</p>
          </div>
          <div class="step">
            <div class="step-number">2</div>
            <h3>TLS proxy intercepts</h3>
            <p>Outbound HTTPS is transparently routed to a per-VM proxy via iptables DNAT. The proxy terminates TLS and reads the target domain from SNI.</p>
          </div>
          <div class="step">
            <div class="step-number">3</div>
            <h3>Credentials injected</h3>
            <p>If the domain is allowlisted, the proxy injects the configured API keys as HTTP headers and forwards to the real service. The agent never sees them.</p>
          </div>
        </div>

        <div class="flow-diagram">
          <pre><span class="hl">Agent in VM</span>: curl https://api.anthropic.com/v1/messages
  <span class="dim">|</span>
  <span class="dim">|--</span> VM resolves api.anthropic.com <span class="dim">(real IP)</span>
  <span class="dim">|--</span> iptables DNAT rewrites destination <span class="dim">--></span> <span class="hl">per-VM proxy</span>
  <span class="dim">|--</span> Proxy terminates TLS, reads SNI
  <span class="dim">|</span>
  <span class="dim">|--</span> Domain in allowlist?
  <span class="dim">|   |--</span> <span class="hl">YES</span>: inject <span class="hl">x-api-key</span> header, forward to real API
  <span class="dim">|   |--</span> <span class="warn">NO</span>:  drop connection <span class="dim">(TCP RST)</span>
  <span class="dim">|</span>
  <span class="dim">|--</span> Agent sees normal HTTPS response
       <span class="hl">Never saw the API key.</span> Not in env, not in memory, not on disk.</pre>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features" id="features">
      <div class="container">
        <p class="section-label">Features</p>
        <h2 class="section-title">Built for zero trust</h2>
        <p class="section-desc">
          Everything an AI agent needs to run safely, with nothing it shouldn't have.
        </p>

        <div class="feature-grid">
          <div class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Zero secrets in the VM</h3>
            <p>API keys never enter the sandbox. A per-VM TLS proxy injects credentials at the network layer. If compromised, there is nothing to steal.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <h3>Sub-second Firecracker boot</h3>
            <p>Memory snapshots restore full VMs in under a second. Each session gets a fresh, ephemeral microVM — the same isolation model as AWS Lambda.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </div>
            <h3>Port exposure via tunnels</h3>
            <p>Agents run fullstack apps inside the VM. Users access them via Pangolin tunnel URLs with per-port access control: SSO, PIN, or email allowlist.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Per-VM TLS MITM proxy</h3>
            <p>Every VM gets its own proxy with an ephemeral CA certificate. One proxy per VM, never shared. Spawned with the VM, killed with the VM.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3>Agent harness</h3>
            <p>Claude Code pre-installed. Provide a prompt and constraints, the workload runs automatically. Bring your own agent framework or use ours.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <h3>Domain allowlisting</h3>
            <p>The VM can only reach domains you explicitly allow. Everything else gets a TCP RST. No cloud metadata endpoint, no lateral movement, no surprises.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="architecture" id="architecture">
      <div class="container">
        <p class="section-label">Architecture</p>
        <h2 class="section-title">Control plane + worker isolation</h2>
        <p class="section-desc">
