{
  "name": "@paws/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Worker service — execute sessions in isolated Firecracker VMs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "start": "bun run src/server.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@paws/domain-browser": "workspace:*",
    "@paws/domain-mcp": "workspace:*",
    "@paws/domain-network": "workspace:*",
    "@paws/domain-session": "workspace:*",
    "@paws/domain-snapshot": "workspace:*",
    "@paws/firecracker": "workspace:*",
    "@paws/logger": "workspace:*",
    "@paws/proxy": "workspace:*",
    "@paws/snapshot-store": "workspace:*",
    "hono": "catalog:",
    "neverthrow": "catalog:",
    "prom-client": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
