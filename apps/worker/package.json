{
  "name": "@paws/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Worker service — execute sessions in isolated Firecracker VMs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "start": "bun run src/server.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paws/firecracker": "workspace:*",
    "@paws/types": "workspace:*",
    "hono": "^4.7.0",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "vitest": "^4.1.2"
  }
}
