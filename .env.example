# /\_/\
# ( o.o )  paws configuration
#  > ^ <
#
# Copy this file to .env and edit:
#   cp .env.example .env

# --- Gateway ------------------------------------------------------------------

# Port for the gateway API server
PORT_GATEWAY=4000

# API key for authenticating requests to the gateway
# Change this to a secure random value in production!
API_KEY=paws-dev-key

# URL of the worker service (gateway dispatches sessions here)
WORKER_URL=http://localhost:3000

# --- Worker -------------------------------------------------------------------

# Port for the worker service
PORT_WORKER=3000

# Maximum concurrent Firecracker VMs
MAX_CONCURRENT_VMS=5

# Maximum queued session requests (beyond concurrent limit)
MAX_QUEUE_SIZE=10

# --- Firecracker / VM ---------------------------------------------------------

# Base data directory for paws (kernels, rootfs, snapshots, VMs, SSH keys)
PAWS_DATA_DIR=/var/lib/paws

# Path to the snapshot directory used for VM restores
SNAPSHOT_DIR=/var/lib/paws/snapshots/agent-latest

# Working directory for active VMs (each session gets a subdirectory)
VM_BASE_DIR=/var/lib/paws/vms

# SSH private key for connecting to VMs
SSH_KEY_PATH=/var/lib/paws/ssh/id_ed25519

# vCPUs allocated per VM (default: 2)
# VM_VCPU_COUNT=2

# Memory per VM in MB (default: 4096)
# VM_MEMORY_MB=4096

# Session timeout in milliseconds (default: 600000 = 10 minutes)
# VM_TIMEOUT_MS=600000
