# /\_/\
# ( o.o )  paws control plane configuration
#  > ^ <
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Then deploy:
#   ./scripts/setup-control-plane.sh
#
# Or manually:
#   docker compose up -d
#   # Then visit https://pangolin.DOMAIN to complete Pangolin setup

# ── Domain ──────────────────────────────────────────────────────────────────
# Base domain. Subdomains are created automatically:
#   fleet.DOMAIN      — paws dashboard + API
#   grafana.DOMAIN    — Grafana dashboards
#   pangolin.DOMAIN   — Pangolin tunnel management dashboard
#   tunnel.DOMAIN     — WireGuard endpoint (DNS-only, no Cloudflare proxy)
#
# DNS records needed (all pointing to your VPS IP):
#   *.DOMAIN          A record (for all subdomains)
#   tunnel.DOMAIN     A record (DNS-only / gray cloud for WireGuard UDP)
DOMAIN=tpops.dev
TUNNEL_DOMAIN=tunnel.tpops.dev
GRAFANA_DOMAIN=grafana.tpops.dev

# ── TLS Certificates ───────────────────────────────────────────────────────
# Email for Let's Encrypt. TLS certs are provisioned automatically via
# HTTP-01 challenge — no Cloudflare or DNS provider account needed.
# Just point *.DOMAIN to your server's IP and set this email.
ACME_EMAIL=admin@example.com

# Optional: Cloudflare DNS API token for DNS-01 challenge (supports wildcards).
# Only needed if you want a single wildcard cert instead of per-subdomain certs.
# Create at: dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=

# ── Paws Auth ───────────────────────────────────────────────────────────────
# API key for authenticating requests to the control plane.
# Generate: openssl rand -hex 24
API_KEY=paws-dev-key

# OIDC session secret — must be 32+ characters.
# Generate: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-32-char-string

# Dex client secret — shared between gateway and Dex.
# Generate: openssl rand -hex 24
OIDC_CLIENT_SECRET=paws-dex-secret-changeme

# ── GitHub Login (via Dex) ──────────────────────────────────────────────────
# Optional. Create OAuth app at https://github.com/settings/developers
# Callback URL: https://fleet.DOMAIN/dex/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Pangolin ────────────────────────────────────────────────────────────────
# Secret for Pangolin sessions — must be 32+ characters.
# Generate: openssl rand -hex 32
PANGOLIN_SECRET=change-me-to-a-random-32-char-string-for-pangolin

# OIDC client secret for Pangolin → Dex SSO (auto-generated by setup script).
# Users log into exposed ports with the same identity as the paws dashboard.
PANGOLIN_OIDC_SECRET=pangolin-dex-secret-changeme

# After Pangolin first-boot: create an API key in the Pangolin dashboard
# and set these so the control plane can discover workers via tunnel.
PANGOLIN_API_URL=http://pangolin:3001/api/v1
PANGOLIN_API_KEY=
PANGOLIN_ORG_ID=

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── LLM Gateway (optional — plugin architecture for LLM proxies) ────────────
# Routes LLM API calls through an external proxy for model routing, cost
# tracking, rate limits, and multi-provider support.
#
# Built-in presets: litellm, openrouter, custom
# Set LLM_GATEWAY to the preset name and LLM_GATEWAY_KEY to the API key.
#
# LiteLLM (self-hosted): docker compose --profile litellm up -d
#   LLM_GATEWAY=litellm
#   LLM_GATEWAY_KEY=sk-paws-litellm
#   LLM_GATEWAY_URL=http://litellm:4001          (default for litellm preset)
#
# OpenRouter (hosted):
#   LLM_GATEWAY=openrouter
#   LLM_GATEWAY_KEY=sk-or-...
#
# Custom proxy:
#   LLM_GATEWAY=custom
#   LLM_GATEWAY_URL=https://my-proxy.internal/v1
#   LLM_GATEWAY_KEY=my-key
#   LLM_GATEWAY_DOMAINS=api.anthropic.com,api.openai.com
#
LLM_GATEWAY=
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=
LITELLM_MASTER_KEY=sk-paws-litellm
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Worker (optional — static URL fallback for dev) ─────────────────────────
WORKER_URL=
