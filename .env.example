# /\_/\
# ( o.o )  paws control plane configuration
#  > ^ <
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Then deploy:
#   ./scripts/setup-control-plane.sh
#
# Or manually:
#   docker compose up -d

# ── Domain ──────────────────────────────────────────────────────────────────
# Base domain. Subdomains are created automatically:
#   fleet.DOMAIN      — paws dashboard + API
#   grafana.DOMAIN    — Grafana dashboards
#
# DNS records needed (all pointing to your VPS IP):
#   *.DOMAIN          A record (for all subdomains)
DOMAIN=tpops.dev
GRAFANA_DOMAIN=grafana.tpops.dev

# ── TLS Certificates ───────────────────────────────────────────────────────
# Email for Let's Encrypt. TLS certs are provisioned automatically via
# HTTP-01 challenge — no Cloudflare or DNS provider account needed.
# Just point *.DOMAIN to your server's IP and set this email.
ACME_EMAIL=admin@example.com

# Optional: Cloudflare DNS API token for DNS-01 challenge (supports wildcards).
# Only needed if you want a single wildcard cert instead of per-subdomain certs.
# Create at: dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=

# ── Paws Auth ───────────────────────────────────────────────────────────────
# API key for authenticating requests to the control plane.
# Generate: openssl rand -hex 24
API_KEY=paws-dev-key

# OIDC session secret — must be 32+ characters.
# Generate: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-32-char-string

# Dex client secret — shared between gateway and Dex.
# Generate: openssl rand -hex 24
OIDC_CLIENT_SECRET=paws-dex-secret-changeme

# ── GitHub Login (via Dex) ──────────────────────────────────────────────────
# Optional. Create OAuth app at https://github.com/settings/developers
# Callback URL: https://fleet.DOMAIN/dex/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── LLM Gateway (optional — route through your existing LLM proxy) ──────────
# If you already run LiteLLM, OpenRouter, or another LLM proxy, paws can
# route agent API calls through it for model routing, cost tracking, etc.
#
# Presets: litellm, openrouter, custom
#
# LiteLLM:
#   LLM_GATEWAY=litellm
#   LLM_GATEWAY_URL=http://your-litellm:4000
#   LLM_GATEWAY_KEY=sk-your-litellm-key
#
# OpenRouter:
#   LLM_GATEWAY=openrouter
#   LLM_GATEWAY_KEY=sk-or-...
#
# Custom:
#   LLM_GATEWAY=custom
#   LLM_GATEWAY_URL=https://your-proxy/v1
#   LLM_GATEWAY_KEY=your-key
#   LLM_GATEWAY_DOMAINS=api.anthropic.com,api.openai.com
#
LLM_GATEWAY=
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=

# ── Worker (optional — static URL fallback for dev) ─────────────────────────
WORKER_URL=
