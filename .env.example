# /\_/\
# ( o.o )  paws configuration
#  > ^ <
#
# Copy this file to .env and edit:
#   cp .env.example .env

# --- Domain -------------------------------------------------------------------

# Your domain — Caddy will auto-provision TLS via Let's Encrypt.
DOMAIN=fleet.example.com

# Grafana subdomain (optional — leave empty to disable external Grafana access).
GRAFANA_DOMAIN=grafana.example.com

# --- Gateway ------------------------------------------------------------------

# API key for authenticating programmatic requests to the gateway.
# Generate with: openssl rand -hex 32
API_KEY=paws-dev-key

# URL of the worker service (if running worker separately).
# Leave empty when worker is not part of this compose stack.
WORKER_URL=

# --- OIDC (Dex) ---------------------------------------------------------------

# Session encryption secret — must be 32+ characters.
# Generate with: openssl rand -hex 16
AUTH_SECRET=change-me-to-a-random-32-char-string

# Dex client secret — must match between gateway and Dex config.
# Generate with: openssl rand -hex 16
OIDC_CLIENT_SECRET=paws-dex-secret-changeme

# --- GitHub Login (via Dex) ---------------------------------------------------

# Create an OAuth app at https://github.com/settings/developers
# Set callback URL to: https://<DOMAIN>/dex/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Grafana ------------------------------------------------------------------

# Admin password for Grafana (default: admin).
GRAFANA_ADMIN_PASSWORD=admin

# --- Worker (only if running separately) --------------------------------------

# Port for the worker service
# PORT_WORKER=3000

# Maximum concurrent Firecracker VMs
# MAX_CONCURRENT_VMS=5

# Maximum queued session requests
# MAX_QUEUE_SIZE=10

# --- Firecracker / VM (only if running worker) --------------------------------

# Base data directory for paws
# PAWS_DATA_DIR=/var/lib/paws

# Snapshot directory for VM restores
# SNAPSHOT_DIR=/var/lib/paws/snapshots/agent-latest

# Working directory for active VMs
# VM_BASE_DIR=/var/lib/paws/vms

# SSH private key for VM access
# SSH_KEY_PATH=/var/lib/paws/ssh/id_ed25519
