{
  "name": "@paws/provider-hetzner-dedicated",
  "version": "0.1.0",
  "private": true,
  "description": "Hetzner Robot API provider for paws — manage dedicated bare-metal servers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paws/providers": "workspace:*",
    "neverthrow": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
