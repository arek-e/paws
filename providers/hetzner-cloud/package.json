{
  "name": "@paws/provider-hetzner-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Hetzner Cloud API provider for paws — gateway/control-plane nodes (no Firecracker support)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "neverthrow": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
