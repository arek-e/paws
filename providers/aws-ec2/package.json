{
  "name": "@paws/provider-aws-ec2",
  "version": "0.1.0",
  "private": true,
  "description": "AWS EC2 provider for paws — worker nodes with /dev/kvm support (Intel Nitro instances)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.750.0",
    "neverthrow": "catalog:"
  },
  "devDependencies": {
    "bun-types": "catalog:",
    "vitest": "catalog:"
  }
}
